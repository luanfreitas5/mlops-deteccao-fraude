# =============================================================================
# .env.example — variáveis de ambiente (copie para .env e preencha).
# NUNCA commite o arquivo .env real. Apenas segredos ficam aqui.
# =============================================================================

# URI de rastreamento do MLflow (padrão local: file:./mlruns).
# Ex.: http://localhost:5000 para um servidor remoto.
MLFLOW_TRACKING_URI=file:./mlruns

# Semente global (opcional; sobrescreve o padrão do config.yaml).
RANDOM_SEED=42

# Credenciais de remote do DVC (ex.: S3) — preencha apenas se aplicável.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
